          "fill": "#FFFFFF35",
          "textGrowth": "fixed-width",
          "width": 280,
          "content": "• Use gradients on the logomark\n• Rotate or skew the logomark\n• Add drop shadows to the logo\n• Use the logomark without the ring\n• Change the proportions of Z to O\n• Place on busy photo backgrounds",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 12,
          "fontWeight": "normal"
